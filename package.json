{
  "name": "boqa",
  "version": "1.4.0",
  "description": "Browser Observability & QA Agent — autonomous decision kernel with bounded execution authority",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "live": "node server.js --mode=live",
    "baseline": "node server.js --mode=baseline",
    "compare": "node server.js --mode=compare",
    "observe": "node server.js --mode=observe",
    "explore": "node server.js --mode=explore",
    "verify": "node server.js --mode=verify",
    "continuous": "node server.js --mode=continuous",
    "ci": "node ci/runner.js --config ci/config.json",
    "demo": "node server.js --mode=live --target https://ripio.com",
    "analyze": "curl -X POST http://localhost:7070/api/analyze",
    "verify-queue": "curl http://localhost:7070/api/verification-queue",
    "metrics": "curl http://localhost:7070/api/metrics",
    "coverage": "curl http://localhost:7070/api/coverage",
    "discovery": "curl http://localhost:7070/api/discovery",
    "hypotheses": "curl http://localhost:7070/api/hypotheses",
    "planner": "curl http://localhost:7070/api/planner",
    "disclosure": "curl -X POST http://localhost:7070/api/disclosure",
    "economic": "curl http://localhost:7070/api/economic",
    "comparator": "curl http://localhost:7070/api/comparator",
    "policy": "curl http://localhost:7070/api/policy",
    "allocation": "curl http://localhost:7070/api/allocation",
    "decision-run": "curl -X POST http://localhost:7070/api/decision-run -H 'Content-Type: application/json' -d '{}'",
    "uncertainty": "curl http://localhost:7070/api/uncertainty",
    "counterfactual": "curl http://localhost:7070/api/counterfactual",
    "stability": "curl http://localhost:7070/api/stability",
    "alignment": "curl http://localhost:7070/api/alignment",
    "test:dashboard": "node test/test-dashboard-smoke.js"
  },
  "keywords": [
    "observability",
    "playwright",
    "instrumentation",
    "security",
    "regression",
    "qa",
    "finding",
    "evidence",
    "disclosure",
    "verification",
    "reproduction",
    "bug",
    "autonomous",
    "discovery",
    "coverage"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
    "express": "^4.18.2",
    "jsondiffpatch": "^0.6.2",
    "playwright": "^1.41.0",
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  }
}

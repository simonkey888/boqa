# BOQA v1.4.0 — environment variable reference
# Copy to .env only in an authorized deployment. Do not commit secrets.

# Backend
BOQA_MODE=live
BOQA_PORT=7070
HEADLESS=true
BOQA_AUTO_ANALYZE=true
BOQA_RATE_LIMIT=60
BOQA_DURATION=0

# Authorized target configuration is fail-closed when omitted.
# Set only to an owned asset, documented authorized asset, fixture, or isolated lab.
# BOQA_TARGET=

# Backend authentication. Production requires both values.
# BOQA_API_KEY=
# BOQA_HMAC_SECRET=
BOQA_HMAC_SKEW_SECONDS=300

# Hunter runtime
BOQA_HUNTER_INTERVAL_MS=300000
BOQA_HUNTER_HEARTBEAT_MS=15000
BOQA_HUNTER_HEARTBEAT_FRESHNESS_MS=60000
BOQA_HUNTER_CYCLE_TIMEOUT_MS=120000
BOQA_HUNTER_LOCK_STALE_MS=600000
# BOQA_RELEASE_SHA=

# Cloudflare Worker bindings. Configure in Cloudflare, not in this file.
# BOQA_BACKEND_URL=http://owned-backend.example.invalid
# BOQA_API_KEY=
# BOQA_HMAC_SECRET=

# Never place billing credentials, cookies, tokens, private keys, or production
# secret values in this example file or in the public dashboard bundle.

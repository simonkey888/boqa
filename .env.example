# ─── BOQA v1.4.0 — Environment Variables ──────────────────────────────
#
# Copy this file to .env (gitignored) and fill in your values.
# All variables are OPTIONAL — defaults are listed below.
#
# ──────────────────────────────────────────────────────────────────────

# ─── Backend (Node.js / Docker container) ─────────────────────────────

# Operating mode. One of: live | baseline | compare | observe | explore | verify | continuous
BOQA_MODE=live

# Target URL the agent will browse and analyze.
BOQA_TARGET=
BOQA_TARGET_ID=

# Port the Express server listens on (inside container).
BOQA_PORT=7070

# API key for the auth gate. If unset, ALL /api/* routes are OPEN (no auth).
# For production: set a strong random string (>= 32 chars).
# To re-enable auth: set this to a non-empty value.
# BOQA_API_KEY=

# HMAC shared secret between Cloudflare Worker and backend.
# If unset, HMAC verification is a no-op (backward compatible).
# If set, EVERY /api/* request MUST include valid X-BOQA-Sig + X-BOQA-Ts
# headers or it's rejected with 401 — even if it bypasses Cloudflare.
# Generate with: openssl rand -hex 32
# BOQA_HMAC_SECRET=

# Run Playwright Chromium headless (recommended for containers).
HEADLESS=true

# Auto-run analysis pipeline every N seconds.
BOQA_AUTO_ANALYZE=true

# Rate limit: max requests per minute per IP (0 = disabled).
BOQA_RATE_LIMIT=60

# Session duration in seconds (0 = unlimited).
BOQA_DURATION=0

# ─── Cloudflare Worker (set in dashboard → Workers → boqa → Settings → Variables) ───

# Backend URL the Worker proxies to. MUST be HTTP (not HTTPS) on port 80
# for Cloudflare free tier compatibility. Use a nip.io domain if your VPS
# has a raw public IP (e.g. http://136.248.83.185.nip.io).
# BOQA_BACKEND_URL=http://your-vps-ip.nip.io

# Same HMAC secret as the backend. MUST match BOQA_HMAC_SECRET exactly.
# If unset, the Worker does NOT sign requests (backward compatible).
# BOQA_HMAC_SECRET=

# (Optional) Override the demo API key shown on /health endpoint.
# BOQA_API_KEY=BOQA123

# ─── Generating a strong HMAC secret ──────────────────────────────────
#
# On Linux/Mac:
#   openssl rand -hex 32
#
# On Windows (PowerShell):
#   -join ((1..32) | ForEach-Object { '{0:x2}' -f (Get-Random -Max 256) })
#
# Set the SAME secret on BOTH:
#   1. Cloudflare Worker → Settings → Variables → BOQA_HMAC_SECRET
#   2. VPS Docker container → -e BOQA_HMAC_SECRET=<same-value>
#
# If the secrets don't match, ALL /api/* requests will return 401 hmac_invalid.

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boqa.invalid/schemas/safe-lab-hunter-contract-v1.schema.json",
  "title": "BOQA Safe Lab Hunter Contract V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "environment", "status", "hunter_state", "reportable",
    "authorized_scope", "target_kind", "policy_id", "source_sha", "run_id",
    "cycle_started_at", "cycle_finished_at", "observed_at", "fresh_until", "unavailable_after",
    "finding_count", "control_finding_count", "false_positive_count", "false_negative_count",
    "unauthorized_connection_count", "cleanup_verified", "egress_blocked",
    "request_budget_verified", "evidence_checksum", "message"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "environment": { "const": "controlled_lab" },
    "status": { "enum": ["FRESH", "STALE", "UNAVAILABLE"] },
    "hunter_state": { "const": "LAB_COMPLETE" },
    "reportable": { "const": false },
    "authorized_scope": { "const": "synthetic_fixture" },
    "target_kind": { "const": "owasp_juice_shop_pinned" },
    "policy_id": { "const": "safe-lab-readonly-v1" },
    "source_sha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "run_id": { "type": "string", "pattern": "^sha256:[a-f0-9]{16}$" },
    "cycle_started_at": { "type": "string", "format": "date-time" },
    "cycle_finished_at": { "type": "string", "format": "date-time" },
    "observed_at": { "type": "string", "format": "date-time" },
    "fresh_until": { "type": "string", "format": "date-time" },
    "unavailable_after": { "type": "string", "format": "date-time" },
    "finding_count": { "const": 1 },
    "control_finding_count": { "const": 0 },
    "false_positive_count": { "const": 0 },
    "false_negative_count": { "const": 0 },
    "unauthorized_connection_count": { "const": 0 },
    "cleanup_verified": { "const": true },
    "egress_blocked": { "const": true },
    "request_budget_verified": { "const": true },
    "evidence_checksum": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "message": { "const": "Validación completada en laboratorio controlado" }
  }
}
